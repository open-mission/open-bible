# dependencies
/node_modules

# git worktrees (used by feature-dev workflow)
/.worktrees/

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# generated bible data (build output from resources/bibles/*.sqlite)
/public/data/bibles/

# typescript
*.tsbuildinfo
next-env.d.ts.env.local

# next-pwa auto-generated files
/public/fallback-*.js
/public/swe-worker-*.js
/public/workbox-*.js


# generated SQLite WASM assets + seed bibles (copied from node_modules/resources)
/public/sqlite-wasm/
/public/bibles/
